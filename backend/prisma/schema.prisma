// ---------------------------------------------------------
// 1. CONFIGURATION & GÉNÉRATEUR
// ---------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ligne retiré suite qu pricinpe de lq nouvelle version 7 prisma
  // url      = env("DATABASE_URL")
  
}

// ---------------------------------------------------------
// ENUMÉRATIONS (Clarté et limitation des valeurs) [cite: 1, 63, 165]
// ---------------------------------------------------------
enum OrderStatus {
  PENDING   // Commande saisie par le serveur

  PENDING_ROOMLINK // Envoyée à la recption, en attente de validation pour la chambre
  CHARGED_TO_ROOM  // Validee et imputé sur le Folio de la chambre

  PRINTED   // Facture imprimée (Verrouillée, en attente d'encaissement à la caisse)
  VALIDATED // Confirmée par le caissier (Paiement reçu)
  LOSS      // Perte (Client parti sans payer, imputé au serveur)
  CANCELLED // Annulée (avec retour en stock)
}

enum MovementType {
  SALE                  // Vente normale
  REQUISITION           // Transfert entre stocks et POS (demande)
  RETURN_AFTER_CANCEL   // Retour suite à annulation facture
  PURCHASE              // Entrée fournisseur(Goods Received)
  INTERNAL_PRODUCTION   // Consommation de matières premières pour une recette (Fiche technique)
  INTERNAL_STAFF        // Nourriture ou consommation du personnel (Staff)
  LOSS                  // Perte ou casse
}

enum ReportStatus {
  SUBMITTED
  CONFIRMED_BY_RECEPTION
  DEPOSITED_TO_MAIN_CASH
}

enum PaymentStatus  {
  UNPAID             // Dette
  PAID                //payé à la reception
  PARTIALLY_PAID
}

enum PurchaseStatus  {
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED     // reception partielle(gate,Gstore,items requisitionés)
  RECEIVED
  REJECTED
}

enum ShiftStatus  {
  OPEN
  CLOSED
}

// ---------------------------------------------------------
// HOTEL (Time & Currency config )
// ---------------------------------------------------------

model Hotel {
  id              Int         @id @default(autoincrement())
  name            String  
  address         String? 
  phone           String?
  email           String? 
  logo            String? 

  timezone        String      @default("Africa/Lubumbashi")     //reference calcul du temps
  dateFormat      String      @default("DD/MM/YYYY")     //monnaie de calcul
  baseCurrency    String      @default("USD")     //monnaie de calcul
  localCurrency   String      @default("FC")     //monnaie local
  currencyExchangeRate   Float      @default(2300)   //taux du jour
  taxeRate        Float       @default(16)       // Rdc taxe TVA: 16%

  //Config hoteliere (regle opperationnelle)
  checkInHour     Int         @default(14)
  checkOutHour    Int         @default(10)
  dayUseMaxHours  Int         @default(6)

  // Gestion A bonnement
  subscriptionEnd      DateTime      @default(now())

  //feature TOGGLING
  isPosEnabled                Boolean         @default(true)
  isStockEnabled              Boolean         @default(true)
  isHousekeepingEnabled       Boolean         @default(true)
  isOvertimeDayuseFeeEnabled  Boolean         @default(false)
  isMultiShiftEnabled         Boolean         @default(false)    //shift partagé( demi) journee)
  maxPosAllowed               Int             @default(2)        //LIMITE POS 

  //Config DAY_USE overtime
  dayUseOvertimeRate         Float          @default(8) // 
  dayUseGracePeriodMins      Int            @default(15)  // 15min gratuites Periode de grace 
  
  
  updatedAt       DateTime    @updatedAt
}


// ---------------------------------------------------------
// 2. UTILISATEURS & RÔLES
// ---------------------------------------------------------
model User {
  id               Int            @id @default(autoincrement())
  name             String
  username         String         @unique // Identifiant de connexion sans escpace surtout(court)
  email            String?         @unique // Indexé par défaut car unique, modify optional
  /// @encrypted
  password         String         // Stockage sécurisé (Hashé via bcrypt dans le service)
  
  roles            UserRole[]
  orders           Order[]        @relation("ServerOrders")
  cashierValidations Order[]      @relation("CashierValidation")
  dailyReports     DailyReport[]
  posShifts        PosShift[]     // user opens shift
  purchaseRequests PurchaseRequest[] // purchase requested by user
  
  createdAt        DateTime       @default(now())

  @@index([username]) // Index pour recherche rapide lors du login
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique // "ADMIN", "CASHIER", "RECEPTIONIST", etc. [cite: 1, 98]
  users UserRole[]
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])
 
  @@id([userId, roleId])
}

// ---------------------------------------------------------
//  STUCTURE MULTI-POS & MENU
// ---------------------------------------------------------
model PointOfSale {
  id                        Int                   @id @default(autoincrement())
  name                      String                @unique                        //"RESAURANT", "BAR", ...
  type                      String                @default("STANDARD")
  isActive                  Boolean               @default(true)

  //Mapping
  printerId                 String?
  printerPort               Int                   @default(9100) //port standard thermal printer

  menus                     PosMenu[]             // fenetre dactivation des articles pour le pos
  orders                    Order[]
  stocks                    Stock[]
  purchaseRequests          PurchaseRequest[]
  posShifts                 PosShift[]

  dailyReports              DailyReport[]      // liason rapport journalier  Pos
}

model PosMenu  {
  posId                     Int
  productId                 Int
  pos                       PointOfSale           @relation(fields: [posId], references: [id])
  product                   Product               @relation(fields: [productId], references: [id])

  // Premium: Prix promotionnel 
  customPrice               Float?
  isActive                  Boolean               @default(true)
  createdAt                 DateTime              @default(now())

  salePrice                 Float

  @@id([posId, productId])
}

// ---------------------------------------------------------
// 3. STOCKS & INVENTAIRE (Avec contraintes de quantité) & FICHE TECHNIQUE CUISINE & MATIERE PREMIERE
// ---------------------------------------------------------
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique // refer to POS
  products Product[]
}

model Product {
  id                       Int          @id @default(autoincrement())
  name                     String
  code                     String       @unique
  defaultPurchasePrice     Float         // Purchase Price (Prix d'achat de Base)
  defaultSalePrice         Float        // Doit être validé > 0 dans le service [cite: 127]

  itemCategory             String
  itemMeasure              String
  itemUnit                 String
  itemGroup                String?
  itemFamily               String?
  itemOrigin               String?
  itemSupplier             String?
  image                    String? 

  isService                Boolean       @default(false)     // true = Service/Abonnement, false = Produit physique stockable

  categoryId               Int
  category                 Category      @relation(fields: [categoryId], references: [id])

  //Relations
  stocks      Stock[]
  posMenus    PosMenu[]                //permet d'activer ce produit sur diff POS
  orderItems  OrderItem[]
  movements   StockMovement[]

  purchaseItems   PurchaseOrderItem[]
  recipes         Recipe[]
  usedInRecipes   RecipeIngredient[]

  @@index([code])
}

model Stock {
  id         Int      @id @default(autoincrement())
  //location   String   // "MAGASIN", "BAR", "CUISINE" [cite: 137]
  quantity   Int      @default(0) // Validation logicielle : toujours >= 0
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])

  posId      Int?
  pos        PointOfSale?   @relation(fields: [posId], references: [id])

  @@unique([productId, posId]) // Un produit ne peut avoir qu'une ligne par lieu
}

model StockMovement {
  id          Int          @id @default(autoincrement())
  productId   Int
  product     Product      @relation(fields: [productId], references: [id]) // rciproque(relation)
  quantity    Int          // Positif pour entrée, négatif pour sortie
  type        MovementType
  from        String
  to          String?
  reason      String?      // Utile pour la traçabilité des annulations
  createdAt   DateTime     @default(now())

  userId      Int          // qui a fait qui (action annuler, valider)

  @@index([productId, createdAt])
}

//Fiche technique / Recette
model Recipe  {
  id                       Int         @id @default(autoincrement())
  productId                Int         @unique
  product                  Product     @relation(fields: [productId], references: [id])
  description              String?
  ingredients              RecipeIngredient[]
}

model RecipeIngredient  {
  id                       Int         @id @default(autoincrement())
  recipeId                 Int
  recipe                   Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId             Int
  ingredient               Product     @relation(fields: [ingredientId], references: [id])
  quantityRequired         Float
}


//Option Controle: Inventaire physique et ecart

model PhysicalInventory  {
  id              Int         @id @default(autoincrement())
  checkedAt       DateTime    @default(now())
  checkedBy       String
  posLocation     String
  notes           String?
  details         InventoryDetail[]
}

model InventoryDetail  {
  id              Int         @id @default(autoincrement())
  inventoryId     Int 
  inventory       PhysicalInventory     @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  productId       Int
  theoreticalQuantity    Float
  realQuantity    Float
  discrepancy     Float
}

// ---------------------------------------------------------
// 4. VENTES & FACTURATION & Encaissements
// ---------------------------------------------------------
model PaymentMethod {
  id              Int          @id @default(autoincrement())
  name            String       @unique // Cash,momo: Airtel m, orange m, Visa,...
  category        String?       // grouper par type
  isActive        Boolean      @default(true) // permet de desactiver sans supprimer
  orders          Order[]
  payments       Payment[]
}

//flux financier
model Payment { 
  id                   Int           @id  @default(autoincrement())
  amount               Float          //montant encaissé lors de la transaction
  createdAt            DateTime      @default(now())
  receivedBy           String        // username

  // Liaison Optionnelle : soit c'est pour une chambre (Folio), soit pour une commande directe (POS)
  folioId              Int?
  folio                Folio?        @relation(fields: [folioId], references: [id]) 


  paymentMethodId      Int
  PaymentMethod        PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([folioId])
 }

model Order {
  id              Int          @id @default(autoincrement())
  orderNumber     String       @unique // Numéro de facture (ex: FAC-2024-001)
  tableName       String?
  totalAmount     Float        @default(0)

  //Discount 
  discountAmount  Float        @default(0)  
  
  status          OrderStatus  @default(PENDING) 

  posId           Int
  pos             PointOfSale  @relation(fields: [posId], references: [id])

  paymentMethodId Int
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  
  userId          Int          // Serveur ayant pris la commande [cite: 169]
  user            User         @relation("ServerOrders", fields: [userId], references: [id])

  shiftId         Int
  shift           PosShift     @relation(fields: [shiftId], references: [id])
  
  cashierId       Int?         // Caissier ayant validé le paiement [cite: 155]
  cashier         User?        @relation("CashierValidation", fields: [cashierId], references: [id])
  
  folioId         Int?         // Si lié à une chambre [cite: 44, 178]
  folio           Folio?       @relation(fields: [folioId], references: [id])

  //Tracabilité de correction 
  correctedFromFolioId         Int?       //stock ID de la mauvaise chambre si correction
  correctionReason             String?    // Motif de la reaffectation par le superviseur
  correctedById                Int?       // Id du supervisuer qui a corrigé
  
  items           OrderItem[]
  createdAt       DateTime     @default(now())
  validatedAt     DateTime?

  @@index([orderNumber])
  @@index([status])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int     // Doit être > 0
  price     Float   // Historisation du prix au moment de la vente [cite: 190, 212]
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model PosShift  {
  id                 Int                    @id @default(autoincrement())
  userId             Int
  user               User                   @relation(fields: [userId], references: [id])
  openedAt           DateTime               @default(now())
  closedAt           DateTime?
  initialFloat       Float
  expectedAmount     Float?
  actualAmount       Float?                                // egal null temps k le shift est open
  status             ShiftStatus            @default(OPEN)

  posId             Int
  pos               PointOfSale             @relation(fields: [posId], references: [id])

  orders             Order[]

//liason avec model dAILY REPORT
  dailyReportId      Int?                       // optionnel vers la cloture generale de la journee
  dailyReport        DailyReport?           @relation(fields: [dailyReportId], references: [id])
}

// ---------------------------------------------------------
// -. DASHBOARD SECURITY & RECEPTION PARTIELLE
// ---------------------------------------------------------

model PurchaseRequest  {
  id                 Int                    @id @default(autoincrement())
  reference          String                 @unique
  status             PurchaseStatus         @default(PENDING_APPROVAL)
  createdAt          DateTime               @default(now())

  requestedById      Int 
  requestedBy        User                   @relation(fields: [requestedById], references: [id])

  posId              Int?
  pos                PointOfSale?           @relation(fields: [posId], references: [id])


  items              PurchaseOrderItem[]
  securityLogs       SecurityGateLog[]

}

model PurchaseOrderItem  {
  id                 Int                    @id @default(autoincrement())
  requestId          Int 
  request            PurchaseRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId          Int
  product            Product                @relation(fields: [productId], references: [id])

  quantityOrdered    Float
  quantityReceived   Float                  @default(0)
  estimatedPrice     Float
  finalPricePaid     Float?
}

model SecurityGateLog {
  id                 Int                    @id @default(autoincrement())
  requestId          Int
  request            PurchaseRequest        @relation(fields: [requestId], references: [id])
  verifiedAt         DateTime               @default(now())
  verifiedBy         String
  gateNotes          String
}


// ---------------------------------------------------------
// 5. HÉBERGEMENT & PMS actualisé
// ---------------------------------------------------------
enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY         // Etat auto apres check-out
  CLEANING      // En cours
  MAINTENANCE   // Out of oder
}

model Room {
  id         Int      @id @default(autoincrement())
  number     String   @unique
  type       String   // Royal SUITE, Standard,etc.
  price      Float    
  status     RoomStatus   @default(AVAILABLE)
  
  isReady    Boolean  @default(true)    //switch Housekeeper
  lastCleanedAt   DateTime  @default(now())

  folios     Folio[]
}

model Guest {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  password   String     //acces siteweb
  phone      String?
  reviews    Review[]   // commentaire du guest
  folios     Folio[]
  createdAt  DateTime  @default(now())
}

model Review {
  id         Int       @id @default(autoincrement())
  content    String
  rating     Int
  guestId    Int
  guest      Guest     @relation(fields: [guestId], references: [id])
  createdAt  DateTime  @default(now())
}

enum StayType {
  NIGHT      //nuitee
  DAY_USE    // hourly booking(3h)
}

enum FolioStatus { 
  RESERVED
  CHECKED_IN
  CHECK_OUT
  CANCELLED
 }

// Petit modification pour lier le client à la chambre
model Folio {
  id         Int       @id @default(autoincrement())
  roomId     Int
  room       Room      @relation(fields: [roomId], references: [id])
  guestId    Int?      // optionnel (client non inscrit: en passage)
  guest      Guest?    @relation(fields: [guestId], references: [id])
  guestName  String    // garger le nom pour archive rapide

  stayType   StayType  @default(NIGHT)
  checkIn    DateTime  @default(now())
  checkOut   DateTime?

  //Gestion depassement timing Day_Use
  isOverTimeWaived          Boolean             @default(false)  //true , si le manager accepte dannuler la penalité
  overtimeWaivedBy          String?             //nom (ID) du user qui a annulé
  waivedAt                  DateTime?           //Date annulation
  reasonForWaive            String?             //obligatoire 

  totalBill       Float          @default(0)     //easy bill separation with Ttamount
  status          FolioStatus    @default(CHECKED_IN)
  paymentStatus   PaymentStatus  @default(UNPAID)
  orders          Order[]
  payments         Payment[]
  
  @@index([roomId, status])
}

// ---------------------------------------------------------
// 6. RAPPORTS & DÉPÔTS (Main Courante) [cite: 55, 317, 428]
// ---------------------------------------------------------
model DailyReport {
  id               Int          @id @default(autoincrement())
  date             DateTime     @default(now())
  
  totalCollected   Float        // Somme physique collectée all shifts
  status           ReportStatus @default(SUBMITTED)
  createdById      Int
  createdBy        User         @relation(fields: [createdById], references: [id])

  //liason Pos removed location
  posId            Int 
  pos              PointOfSale  @relation(fields: [posId], references: [id])

  shifts           PosShift[]  // permet de voir les shifts demi-journee

  @@index([date, posId])
}